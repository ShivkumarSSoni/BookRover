# BookRover Backend — environment variables
# Copy this file to .env and fill in the values for local development.
# Never commit .env — it is in .gitignore.

APP_ENV=dev
DYNAMODB_REGION=ap-south-1

# Set this when running moto_server locally (pip install "moto[server]"; moto_server -p 8001)
# Leave blank in production — Lambda uses the real AWS endpoint.
DYNAMODB_ENDPOINT_URL=http://localhost:8001

TABLE_PREFIX=bookrover

# CORS: restrict to your CloudFront URL in production.
# In dev, ["*"] allows requests from localhost.
CORS_ALLOWED_ORIGINS=["*"]
